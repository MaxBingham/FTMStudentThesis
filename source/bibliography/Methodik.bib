@inproceedings{kim_performance_2017,
	title = {Performance evaluation of safety sensors in the indoor fog chamber},
	url = {https://ieeexplore.ieee.org/document/7890317/},
	doi = {10.1109/UT.2017.7890317},
	abstract = {In this study, the visibility performance test of safety sensors is carried out in the indoor fog chamber and the effect of the concentration of the fog on the visibility of safety sensors is evaluated. First, safety sensors and outdoor environmental requirements are explained. And also, the relationship between the visibility and the performance of safety sensors is discussed and the current problems for evaluating visibility performance are described. Next, the indoor fog chamber is introduced and spectral transmittance measuring equipment for evaluating the visibility reduction is described. Finally, the use conditions of safety sensors in the outdoors are discussed by measuring the reduction of visibility due to fog and performing preliminary experiments on visibility and sensor performance.},
	urldate = {2026-01-26},
	booktitle = {2017 {IEEE} {Underwater} {Technology} ({UT})},
	author = {Kim, Bong Keun and Sumi, Yasushi},
	month = feb,
	year = {2017},
	keywords = {Laser radar, Safety, Fog, IEC Standards, Indoor Fog Chamber, LiDAR Sensor, Performance evaluation, Robot sensing systems, Safety Sensor, Visibility},
	pages = {1--3},
	file = {Full Text PDF:files/158/Kim und Sumi - 2017 - Performance evaluation of safety sensors in the indoor fog chamber.pdf:application/pdf},
}

